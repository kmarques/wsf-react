dDeprecatedRules":"34"},{"filePath":"64","messages":"65","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},"/Users/karl/projects/2020-2021/wsf-react/src/index.js",[],["66","67"],"/Users/karl/projects/2020-2021/wsf-react/src/App.js",[],"/Users/karl/projects/2020-2021/wsf-react/src/reportWebVitals.js",[],"/Users/karl/projects/2020-2021/wsf-react/src/components/List/List.js",[],"/Users/karl/projects/2020-2021/wsf-react/src/components/List/Item.js",[],["68","69"],"/Users/karl/projects/2020-2021/wsf-react/src/components/List/Form.js",[],"/Users/karl/projects/2020-2021/wsf-react/src/context/todo.js",[],"/Users/karl/projects/2020-2021/wsf-react/src/components/Header.js",[],"/Users/karl/projects/2020-2021/wsf-react/src/components/Body.js",["70"],"import { Container, Typography } from \"@material-ui/core\";\nimport React from \"react\";\nimport { Route, Switch } from \"react-router\";\nimport HomeView from \"../views/HomeView\";\nimport ItemView from \"../views/ItemView\";\nimport ListView from \"../views/ListView\";\n\nexport default function Body() {\n  return (\n    <div style={{ flex: 1 }}>\n      <Container maxWidth=\"lg\">\n        <Typography variant=\"h1\" align=\"center\">\n          MyBody\n        </Typography>\n        <Switch>\n          <Route path=\"/list\">\n            <ListView />\n          </Route>\n          <Route path=\"/\">\n            <HomeView />\n          </Route>\n        </Switch>\n      </Container>\n    </div>\n  );\n}\n","/Users/karl/projects/2020-2021/wsf-react/src/components/Footer.js",[],"/Users/karl/projects/2020-2021/wsf-react/src/views/ListView.js",[],"/Users/karl/projects/2020-2021/wsf-react/src/views/HomeView.js",["71"],"import React, { useState } from \"react\";\nimport { Link } from \"react-router-dom\";\nimport Button from \"../components/Button\";\nimport logo from \"../logo.svg\";\n\nexport default function HomeView() {\n  const buttons = [\n    { title: \"bonjour\", variant: \"contained\", color: \"red\", img: logo },\n    {\n      title: \"bonsoir\",\n      variant: \"contained\",\n      color: \"primary\",\n      onClick: () => alert(\"bonsoir\"),\n    },\n    { title: \"bonsocdsqfqsir\", variant: \"contained\", color: \"secondary\" },\n    { title: \"light\", variant: \"contained\", color: \"primary\", toto: \"text\" },\n    { title: \"dark\", variant: \"contained\", color: \"inherit\", toto: \"text\" },\n  ];\n\n  return (\n    <header className=\"App-header\">\n      {buttons.map((button, index) => (\n        <Button\n          key={index}\n          title={button.title}\n          color={button.color}\n          img={button.img}\n          onClick={button.onClick}\n          variant={button.variant}\n          toto={button.toto}\n        />\n      ))}\n      <Button variant=\"text\" component={Link} to=\"/list\" title={\"Go to List\"} />\n    </header>\n  );\n}\n","/Users/karl/projects/2020-2021/wsf-react/src/views/ItemView.js",[],"/Users/karl/projects/2020-2021/wsf-react/src/components/Button.js",[],"/Users/karl/projects/2020-2021/wsf-react/src/theme.js",[],{"ruleId":"72","replacedBy":"73"},{"ruleId":"74","replacedBy":"75"},{"ruleId":"72","replacedBy":"76"},{"ruleId":"74","replacedBy":"77"},{"ruleId":"78","severity":1,"message":"79","line":5,"column":8,"nodeType":"80","messageId":"81","endLine":5,"endColumn":16},{"ruleId":"78","severity":1,"message":"82","line":1,"column":17,"nodeType":"80","messageId":"81","endLine":1,"endColumn":25},"no-native-reassign",["83"],"no-negated-in-lhs",["84"],["83"],["84"],"no-unused-vars","'ItemView' is defined but never used.","Identifier","unusedVar","'useState' is defined but never used.","no-global-assign","no-unsafe-negation"]